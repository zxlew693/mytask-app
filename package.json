{
  "name": "mytask-app",
  "version": "0.0.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "ng": "ng",
    "start:ng": "ng serve --port 8888",
    "build:electron": "tsc -p electron/tsconfig.json",
    "start:electron": "cross-env NODE_ENV=development electron dist-electron/main.js",
    "electron:wait": "wait-on http://localhost:8888 && npm run build:electron && npm run start:electron",
    "dev": "concurrently --kill-others \"npm run start:ng\" \"npm run electron:wait\"",
    "build": "ng build --configuration production && npm run build:electron",
    "package": "npm run build && electron-forge package",
    "make": "npm run build && electron-forge make",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@angular/cdk": "^21.2.10",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/material": "^21.2.10",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@fontsource/lexend": "^5.2.11",
    "@tailwindcss/vite": "^4.3.0",
    "better-sqlite3": "^12.9.0",
    "rxjs": "~7.8.0",
    "sql.js": "^1.14.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.0.1",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "wait-on": "^9.0.5"
  }
}
